package Lista_1;

import java.util.Scanner;

public class Exercicio_4 {
	
	public static void preencheVetor (int [] vetor, Scanner s) {
		for(int i = 0; i < vetor.length; i++) {
			System.out.println("Informe o vetor " + (i + 1));
			vetor[i] = s.nextInt();
		}
		
	}
	
	public static void imprimeVetor (int [] vetor) {
		for(int i = 0; i <vetor.length ; i++) {
			System.out.print(vetor[i] + " ");
		}
	}
	
	public static int local (int [] vetor, Scanner s) {
		System.out.println("\nBora achar esse valor no x??");
		int x = s.nextInt();
		
		for(int i = 0; i < vetor.length; i++) {
			if (vetor[i] == x) {
			
			return i;	
		}
			else {
				return -1;
			}
		}
		
		return 0;
	}

	public static void main(String[] args) {
		Scanner s = new Scanner(System.in);
		
		int lista [] = new int [4];
		
		preencheVetor (lista, s);
		imprimeVetor (lista);
		
		int posicoes = (local(lista,s));
		if(posicoes == -1) {
			System.out.println("Valor não encontrado :(");
		}
		else {
			System.out.println("EBA foi encontrado na posição: " + posicoes);
		}

	}

}
