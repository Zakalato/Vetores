package Lista_1;

import java.util.Scanner;

public class Exercicio_10 {
	
	
	public static void preencheA(String [] A , Scanner s) {
		for(int i = 0; i < A.length; i++) {
			System.out.println("Digite uma letra (LISTA A)");
			A[i] = s.next();
		}
		
	}
	public static void preencheB(String [] B, Scanner s) {
		for(int i = 0 ; i < B.length; i++) {
			System.out.println("Digite uma letra (LISTA B)");
			B[i] = s.next();
		}
	}
	
	public static boolean iguais (String [] A, String [] B) {
		boolean iguais = true;
		for(int x = 0; x < A.length; x++) {
			boolean contem = false;
			for(int y = 0; y < B.length; y++) {
				if(A[x].equalsIgnoreCase(B[y])) {
					contem = true;
					break;
				}
				
			}
		if(!contem) {
			iguais = false;
			break;
		}
	 }
	return iguais;
	}

	public static void main(String[] args) {
		String A [] = new String [5];
		String B [] = new String [5];
		Scanner s = new Scanner(System.in);
		
		preencheA(A , s);
		preencheB(B , s);
		if(iguais(A,B)) {
			System.out.println("São iguais");
		}
		else {
			System.out.println("São diferentes");
		}
		

	}

}
