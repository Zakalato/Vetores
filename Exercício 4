package Lista_1;

import java.util.Scanner;

public class Exercicio_4 {
	
	public static void preencheVetor (int [] vetor, Scanner s) {
		for(int i = 0; i < vetor.length; i++) {
			System.out.println("Informe o vetor " + (i + 1));
			vetor[i] = s.nextInt();
		}
		
	}
	
	public static void imprimeVetor (int [] vetor) {
		for(int i = 0; i <vetor.length ; i++) {
			System.out.print(vetor[i] + " ");
		}
	}
	
	public static void encontrou (int vetor [], Scanner s) {
		System.out.println("\nQual o seu valor de x?");
		int x = s.nextInt();
		
		for(int u = 0; u < vetor.length; u++) {
			if(vetor [u] == x) {
				System.out.println("Foi encontrado na posição: " + (u + 1) + "°");
				
			}
			else {
				System.out.println("Não foi encontado");
			}
		}
	}
	

	public static void main(String[] args) {
		Scanner s = new Scanner(System.in);
		

		int lista [] = new int [5];
		
		preencheVetor (lista, s);
		imprimeVetor (lista);
		encontrou(lista,s);
		
	}

}
