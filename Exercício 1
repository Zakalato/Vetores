package Lista_1;
import java.util.Scanner;

public class Exercicio_1 {
	
	
	public static void preencheVetor (int [] vetor, Scanner s) {
		for(int i = 0; i < vetor.length; i++) {
			System.out.println("Informe o vetor " + (i + 1));
			vetor[i] = s.nextInt();
		}
		
	}
	
	public static void imprimeVetor (int [] vetor) {
		for(int i = 0; i <vetor.length ; i++) {
			System.out.print(vetor[i] + " ");
		}
		
	}
	
	public static int somar(int vetor [], Scanner s) {
		System.out.println("\nInforme a localização de X entre 0 e " + (vetor.length));
		int x = s.nextInt();
		while(x < 0 || x > vetor.length) {
			System.out.println("Valor incorreto, tente novamente. Entre 0 e " + (vetor.length));
			x = s.nextInt();
		}
		System.out.println("Informe a localização de Y entre 0 e " + (vetor.length));
		int y = s.nextInt();
		while (y < 0 || y > vetor.length) {
			System.out.println("Valor incorreto, tente novamente. Entre 0 e " + (vetor.length));
			y = s.nextInt();
		}
		
		
		
		return x + y;
	}
	
	
	public static void main(String[] args) {
		Scanner s = new Scanner(System.in);
		int [] lista = new int [5];
		
		preencheVetor(lista,s);
		imprimeVetor(lista);
		
		System.out.println(somar(lista,s));
		
		
		
		

	}

}
