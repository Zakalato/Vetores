package Lista_1;

import java.util.Scanner;

public class Exercicio_2 {
	
	public static void preencheVetor (int [] vetor, Scanner s) {
		for(int i = 0; i < vetor.length; i++) {
			System.out.println("Informe o vetor " + (i + 1));
			vetor[i] = s.nextInt();
			while(vetor[i] % 2 == 0) {
				System.out.println("Ce sabe que so vai guardar os impares né? \nInforme o vetor " + (i + 1));
				vetor[i] = s.nextInt();
			}
		}
		
	}
	
	public static void imprimeVetor (int [] vetor) {
		for(int i = 0; i <vetor.length ; i++) {
			System.out.print(vetor[i] + " ");
		}
	}
	

	public static void main(String[] args) {
		Scanner s = new Scanner(System.in);
		
		int lista [] = new int [3];
		
		preencheVetor(lista,s);
		imprimeVetor(lista);

	}

}
