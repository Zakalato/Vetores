package Lista1;

import java.util.Scanner;


public class Exercicio_11 {

    static int repetidos = 0;

    public static void preencheVetor (int [] vetor, Scanner s) {
        for(int i = 0; i < vetor.length; i++) {
            System.out.println("Informe o vetor " + (i + 1));
            vetor[i] = s.nextInt ();
        }
    }
    public static void imprimeVetor (int [] vetor) {
        for(int i = 0; i< vetor.length; i++) {
            System.out.print(vetor[i] + " ");
        }
        System.out.print("\n");
    }
    public static void Ler (int [] vetor) {
        for(int i = 0; i < vetor.length; i++) {
            boolean jaApareceu = false;
            for(int j = 0; j < i; j++) {
                if (vetor[i] == vetor[j]) {
                    jaApareceu = true;
                    break;
                }
            }

            if (!jaApareceu) {
              
            boolean repetido = false;
            for(int j = i + 1; j < vetor.length; j++) {
                if (vetor[i] == vetor[j]) {
                    
                    repetido = true;
                }
            }
            if (repetido) {
                System.out.println("O número " + vetor[i] + " se repete na casa " + (i + 1));
                repetidos++;
            }
        }

        }
        System.out.println("O número de repetições é: " + repetidos);
    }

    public static void main (String [] agrs) {
        Scanner s = new Scanner(System.in);
        int [] lista = new int [5];

        preencheVetor(lista, s);
        imprimeVetor(lista);
        Ler(lista);

        s.close();
    }
}
