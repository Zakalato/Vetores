package Lista_1;

import java.util.Scanner;

  public class Exercicio_5 {
	  static int cont = 0;

	
	public static void preencheVetor (int [] vetor, Scanner s) {
		for(int i = 0; i < vetor.length; i++) {
			System.out.println("Informe a posição: " + (i + 1) + "°");
			vetor[i] = s.nextInt();
			
		}
		
	}
	
	public static void imprimeVetor (int [] vetor) {
		for(int i = 0; i <vetor.length ; i++) {
			System.out.print(vetor[i] + " ");
		}
	}
	
	public static int cont (int [] vetor) {
		  cont = 0;
		for(int i = 0; i < vetor.length; i++) {
			if(vetor[i] % 2 == 0)
				cont++;
		
		}
		return cont;
	}
	

	public static void main(String[] args) {
		Scanner s = new Scanner(System.in);
		
		int lista [] = new int [15];
		
		preencheVetor(lista,s);
		imprimeVetor(lista);
		cont(lista);
        System.out.println("\nQuantidade de pares: " + (cont));
	}

  }
